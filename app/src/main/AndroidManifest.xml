<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Family_Tasks_Proj">

        <!-- מסכי הורה אחרי התחברות -->
        <!-- מסכי הורה — adjustResize כדי שהמקלדת לא תסתיר שדות קלט -->
        <activity
            android:name=".Parents_Dashbord_and_mange.AssignTaskToChildActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".Parents_Dashbord_and_mange.ParentTaskTemplateActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".Parents_Dashbord_and_mange.ParentDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".Parents_Dashbord_and_mange.ManageChildrenActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".Parents_Dashbord_and_mange.GenerateQRActivity"
            android:exported="false" />

        <!-- מסך פתיחה ראשי — adjustResize בגלל שדות login/register -->
        <activity
            android:name=".auth.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="stateHidden|adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- מסכי ילד -->
        <activity
            android:name=".child.ChildDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".Child_Login.ChildSelectionActivity"
            android:exported="false" />

        <!-- מסך סריקת QR -->
        <activity
            android:name="com.journeyapps.barcodescanner.CaptureActivity"
            android:screenOrientation="fullSensor"
            tools:replace="screenOrientation" />
    </application>

</manifest>
