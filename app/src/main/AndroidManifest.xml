<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- הרשאת מצלמה נדרשת לסריקת קוד ה-QR שההורה מציג -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- מצלמה היא לא חובה: הורים יכולים להשתמש באפליקציה גם בלי מצלמה -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Family_Tasks_Proj">

        <!-- מסכי הורה אחרי התחברות -->
        <!-- מסכי הורה: adjustResize כדי שהמקלדת לא תסתיר שדות קלט -->
        <activity
            android:name=".parent.AssignTaskToChildActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".parent.ParentTaskTemplateActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".parent.ParentDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".parent.ManageChildrenActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".parent.GenerateQRActivity"
            android:exported="false" />

        <!-- מסך פתיחה ראשי: adjustResize בגלל שדות התחברות והרשמה -->
        <activity
            android:name=".auth.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="stateHidden|adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- מסכי ילד -->
        <activity
            android:name=".child.ChildDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".auth.ChildSelectionActivity"
            android:exported="false" />

        <!-- מסך סריקת QR -->
        <activity
            android:name="com.journeyapps.barcodescanner.CaptureActivity"
            android:screenOrientation="fullSensor"
            tools:replace="screenOrientation" />
    </application>

</manifest>
