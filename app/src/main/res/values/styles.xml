<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Widget" />
    <style name="Widget.Family" />

    <style name="Widget.Family.ScreenTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="Widget.Family.ScreenSubtitle">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="Widget.Family.HeroTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="Widget.Family.HeroSubtitle">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="Widget.Family.SectionTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Family.Eyebrow">
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="Widget.Family.HelperText">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="Widget.Family.FieldLabel">
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Family.MetricValue">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="Widget.Family.MetricLabel">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Family.PanelTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Family.PanelSubtitle">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="Widget.Family.RoleTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Family.RoleBody">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="Widget.Family.BadgeText">
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Family.PrimaryButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/text_inverse</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:drawablePadding">10dp</item>
        <item name="android:drawableTint" tools:targetApi="m">@color/text_inverse</item>
    </style>

    <style name="Widget.Family.AccentButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_accent</item>
        <item name="android:textColor">@color/text_inverse</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:drawablePadding">10dp</item>
        <item name="android:drawableTint" tools:targetApi="m">@color/text_inverse</item>
    </style>

    <style name="Widget.Family.SmallAccentButton" parent="Widget.Family.AccentButton">
        <item name="android:textSize">13sp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.Family.SecondaryButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_outlined</item>
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:drawablePadding">10dp</item>
        <item name="android:drawableTint" tools:targetApi="m">@color/primary_dark</item>
    </style>

    <style name="Widget.Family.CompactSecondaryButton" parent="Widget.Family.SecondaryButton">
        <item name="android:textSize">13sp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.Family.ChildOutlineButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_secondary_outlined</item>
        <item name="android:textColor">@color/accent_dark</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:drawablePadding">10dp</item>
        <item name="android:drawableTint" tools:targetApi="m">@color/accent_dark</item>
    </style>

    <style name="Widget.Family.QuietButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_quiet</item>
        <item name="android:textColor">@color/logout_text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:drawablePadding">8dp</item>
        <item name="android:drawableTint" tools:targetApi="m">@color/logout_text</item>
    </style>

    <style name="Widget.Family.DangerOutlineButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_danger_outline</item>
        <item name="android:textColor">@color/danger</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:drawablePadding">8dp</item>
        <item name="android:drawableTint" tools:targetApi="m">@color/danger</item>
    </style>

    <style name="Widget.Family.BackButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_back</item>
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:drawablePadding">8dp</item>
        <item name="android:drawableTint" tools:targetApi="m">@color/primary_dark</item>
    </style>

    <style name="Widget.Family.LinkButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_ghost</item>
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">32dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
    </style>

    <style name="Widget.Family.DashboardCardButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_card_clear</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:minHeight">118dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:padding">12dp</item>
        <item name="android:drawablePadding">10dp</item>
        <item name="android:drawableTint" tools:targetApi="m">@color/primary_dark</item>
    </style>

    <style name="AppButton.Primary" parent="Widget.Family.PrimaryButton" />
    <style name="AppButton.Secondary" parent="Widget.Family.AccentButton" />
    <style name="AppButton.Outlined" parent="Widget.Family.SecondaryButton" />

    <style name="AppCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="strokeColor">@color/divider_light</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="AppTextField" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_card</item>
        <item name="boxStrokeColor">@color/md_theme_primary</item>
        <item name="boxStrokeErrorColor">@color/md_theme_error</item>
        <item name="hintTextColor">@color/md_theme_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Family.Medium</item>
        <item name="startIconTint">@color/text_secondary</item>
        <item name="endIconTint">@color/text_secondary</item>
    </style>

    <style name="Widget.Family.TextInputLayout" parent="AppTextField" />

    <style name="Widget.Family.TextInputEditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:textSize">15sp</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
    </style>

</resources>
