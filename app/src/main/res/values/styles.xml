<?xml version="1.0" encoding="utf-8"?>
<!-- סטיילים משותפים בשימוש בלבד. כותרת מסך, טקסט עזר, ושני כפתורים. -->
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Widget" />
    <style name="Widget.Family" />

    <!-- כותרת מסך - שימוש למעלה ראש המסכים -->
    <style name="Widget.Family.ScreenTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.0</item>
    </style>

    <!-- כותרת משנה מתחת לכותרת המסך -->
    <style name="Widget.Family.ScreenSubtitle">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <!-- שורת פתיחה קטנה מעל כותרת -->
    <style name="Widget.Family.Eyebrow">
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.0</item>
    </style>

    <!-- טקסט עזר/הסבר קצר בתוך כרטיסים -->
    <style name="Widget.Family.HelperText">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <!-- תווית של שדה טופס -->
    <style name="Widget.Family.FieldLabel">
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- כפתור ראשי כהה עם טקסט בהיר -->
    <style name="Widget.Family.PrimaryButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/text_inverse</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:drawablePadding">10dp</item>
        <item name="android:drawableTint">@color/text_inverse</item>
    </style>

    <!-- כפתור חזרה (אאוטליין בהיר) -->
    <style name="Widget.Family.BackButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_back</item>
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:drawablePadding">8dp</item>
        <item name="android:drawableTint">@color/primary_dark</item>
    </style>

    <!-- סטייל ברירת מחדל ל-TextInput בערכת הנושא -->
    <style name="AppTextField" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_card</item>
        <item name="boxStrokeColor">@color/md_theme_primary</item>
        <item name="boxStrokeErrorColor">@color/md_theme_error</item>
        <item name="hintTextColor">@color/md_theme_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Family.Medium</item>
        <item name="startIconTint">@color/text_secondary</item>
        <item name="endIconTint">@color/text_secondary</item>
    </style>

</resources>
