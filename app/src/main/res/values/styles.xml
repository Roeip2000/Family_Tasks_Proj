<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget" />
    <style name="Widget.Family" />

    <style name="Widget.Family.ScreenTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Family.ScreenSubtitle">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="Widget.Family.HeroTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Family.HeroSubtitle">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="Widget.Family.SectionTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Family.Eyebrow">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Family.HelperText">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="Widget.Family.FieldLabel">
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Family.MetricValue">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Family.MetricLabel">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Family.PanelTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Family.PanelSubtitle">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="Widget.Family.RoleTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Family.RoleBody">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="Widget.Family.BadgeText">
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Family.PrimaryButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/text_inverse</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:minWidth">0dp</item>
    </style>

    <style name="Widget.Family.AccentButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_accent</item>
        <item name="android:textColor">@color/text_inverse</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:minWidth">0dp</item>
    </style>

    <style name="Widget.Family.SmallAccentButton" parent="Widget.Family.AccentButton">
        <item name="android:textSize">13sp</item>
        <item name="android:minHeight">40dp</item>
    </style>

    <style name="Widget.Family.SecondaryButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">0dp</item>
    </style>

    <style name="Widget.Family.CompactSecondaryButton" parent="Widget.Family.SecondaryButton">
        <item name="android:textSize">13sp</item>
        <item name="android:minHeight">40dp</item>
    </style>

    <style name="Widget.Family.QuietButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_quiet</item>
        <item name="android:textColor">@color/logout_text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">46dp</item>
        <item name="android:minWidth">0dp</item>
    </style>

    <style name="Widget.Family.BackButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_back</item>
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">0dp</item>
    </style>

    <style name="Widget.Family.LinkButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_ghost</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">32dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
    </style>

</resources>
