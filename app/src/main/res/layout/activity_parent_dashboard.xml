<?xml version="1.0" encoding="utf-8"?>
<!--
 דשבורד הורה — מבנה task-first:
 1) כותרת קומפקטית עם אווטאר לחיץ (מחליף תמונה) וקישור "עריכה" שקט.
 2) שורת הקשר אחת עם ספירות inline — לא "דשבורד מטריקות".
 3) בורר ילדים כצ'יפים אופקיים דקים.
 4) טאבים ברורים עם מצב נבחר מלא, לפני רשימת המשימות.
 5) רשימת המשימות היא המרכז הוויזואלי של המסך.
 6) CTA ראשי בולט, פעולות משניות שקטות, התנתקות שקטה.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="18dp"
        android:paddingEnd="16dp"
        android:paddingBottom="28dp">

        <!-- שורת זהות הורה — האווטאר עצמו לחיץ ומפעיל את בורר התמונה -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivParentProfile"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_avatar_placeholder"
                android:clickable="true"
                android:clipToOutline="true"
                android:contentDescription="@string/cd_profile_image"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackgroundBorderless"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/Widget.Family.Eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/parent_dashboard_header_title" />

                <TextView
                    android:id="@+id/tvParentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- קישור קטן לעריכה — שקט, לא מתחרה עם שם ההורה -->
            <Button
                android:id="@+id/btnChangeProfilePic"
                style="@style/Widget.Family.LinkButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_change_parent_photo" />
        </LinearLayout>

        <!-- שורת סטטוס inline קצרה — מחליפה את ה"סטריפ מטריקות" שנראה מלאכותי -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvParentTotalTasks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_zero"
                android:textColor="@color/primary_dark"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@string/filter_open_tasks"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:text="·"
                android:textColor="@color/text_hint"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvParentDueSoon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_zero"
                android:textColor="@color/urgent"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@string/filter_urgent"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:text="·"
                android:textColor="@color/text_hint"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvParentCompleted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_zero"
                android:textColor="@color/success_dark"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@string/filter_completed"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- בורר ילדים כצ'יפים דקים — שם בצד האווטאר, בלי סטטיסטיקות נלוות -->
        <TextView
            style="@style/Widget.Family.Eyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/parent_dashboard_children_title" />

        <TextView
            android:id="@+id/tvNoChildren"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="start"
            android:text="@string/parent_dashboard_no_children"
            android:textColor="@color/text_hint"
            android:textSize="13sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChildren"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never"
            android:paddingStart="2dp"
            android:paddingEnd="2dp" />

        <!-- כרטיס אזור-עבודה: מאחד בתוך מסגרת אחת את ההקשר (הילד הנבחר + סטטיסטיקה),
             את הטאבים לסינון, ואת רשימת המשימות. זה מקבע את ההיררכיה של המסך. -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border_light"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="14dp"
                android:paddingEnd="16dp"
                android:paddingBottom="14dp">

                <!-- הטקסט מתעדכן ב-Activity: "המשימות של דני" -->
                <TextView
                    android:id="@+id/tvTaskSectionTitle"
                    style="@style/Widget.Family.SectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/parent_dashboard_selected_child_empty_title"
                    android:textSize="16sp" />

                <!-- שורת סטטיסטיקה של הילד הנבחר — מוגדרת מ-Java לפי הבחירה -->
                <TextView
                    android:id="@+id/tvTaskSectionSubtitle"
                    style="@style/Widget.Family.HelperText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/parent_dashboard_selected_child_empty_subtitle" />

                <!-- פילטרים: דחופות / פתוחות / הושלמו -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_tab_bar"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/filterUrgentTasks"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:paddingStart="6dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="6dp"
                        android:paddingBottom="10dp"
                        android:text="@string/filter_urgent"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/filterOpenTasks"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:paddingStart="6dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="6dp"
                        android:paddingBottom="10dp"
                        android:text="@string/filter_open_tasks"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/filterCompletedTasks"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:paddingStart="6dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="6dp"
                        android:paddingBottom="10dp"
                        android:text="@string/filter_completed"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/filterAllTasks"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- הודעת-ריק: מופיעה רק כשרשימת המשימות ריקה עבור הפילטר הנבחר -->
                <TextView
                    android:id="@+id/tvNoTasks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:layout_marginBottom="10dp"
                    android:gravity="center"
                    android:text="@string/parent_dashboard_selected_child_empty_subtitle"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <ListView
                    android:id="@+id/lvTasks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="0dp"
                    android:listSelector="@android:color/transparent"
                    android:nestedScrollingEnabled="true" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CTA עיקרי — הפעולה החשובה של המסך הזה -->
        <Button
            android:id="@+id/btnAssignTaskToChild"
            style="@style/Widget.Family.PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/btn_assign_task" />

        <!-- פעולות משניות בשורה אחת, קומפקטיות ושקטות יותר מה-CTA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnManageChildren"
                style="@style/Widget.Family.CompactSecondaryButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:text="@string/btn_manage_children_short" />

            <Button
                android:id="@+id/btnManageTemplates"
                style="@style/Widget.Family.CompactSecondaryButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:text="@string/btn_manage_templates_short" />

            <Button
                android:id="@+id/btnShowQR"
                style="@style/Widget.Family.CompactSecondaryButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="@string/btn_show_children_qr_short" />
        </LinearLayout>

        <Button
            android:id="@+id/btnLogout"
            style="@style/Widget.Family.QuietButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:text="@string/btn_logout" />

    </LinearLayout>

</ScrollView>
