<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FBFBFB"
    android:fillViewport="true"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER: Greeting & Logout -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="שלום,"
                    android:textColor="#888888"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tvParentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="הורה יקר"
                    android:textColor="#2D3436"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/btnLogout"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="התנתק"
                android:textColor="#D63031" />
        </RelativeLayout>

        <!-- INTERACTIVE SUMMARY: These are now the main filters -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:baselineAligned="false">

                <!-- Filter: Open -->
                <LinearLayout
                    android:id="@+id/containerFilterOpen"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/tvParentTotalTasks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#2D3436"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="פתוחות"
                        android:textColor="#888888"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- Filter: Urgent -->
                <LinearLayout
                    android:id="@+id/containerFilterUrgent"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/tvParentDueSoon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#D35400"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="דחופות"
                        android:textColor="#888888"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- Filter: Overdue -->
                <LinearLayout
                    android:id="@+id/containerFilterOverdue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/tvParentOverdue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#D63031"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="באיחור"
                        android:textColor="#888888"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- Filter: Completed -->
                <LinearLayout
                    android:id="@+id/containerFilterCompleted"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/tvParentCompleted"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#27AE60"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="בוצעו"
                        android:textColor="#888888"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CONTROL PANEL -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:columnCount="2"
            android:rowCount="2">
            <Button
                android:id="@+id/btnAssignTaskToChild"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:backgroundTint="#2D3436"
                android:text="הקצאת משימה"
                app:cornerRadius="12dp" />
            <Button
                android:id="@+id/btnManageChildren"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="ניהול ילדים"
                android:textColor="#2D3436"
                app:cornerRadius="12dp"
                app:strokeColor="#DFE4EA" />
            <Button
                android:id="@+id/btnManageTemplates"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="תבניות"
                android:textColor="#2D3436"
                app:cornerRadius="12dp"
                app:strokeColor="#DFE4EA" />
            <Button
                android:id="@+id/btnShowQR"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="קוד QR"
                android:textColor="#2D3436"
                app:cornerRadius="12dp"
                app:strokeColor="#DFE4EA" />
        </GridLayout>

        <!-- TASK LIST: The title changes based on top selection -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTaskSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="כל המשימות"
                android:textColor="#2D3436"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvNoTasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:padding="40dp"
                android:text="אין משימות בקטגוריה זו"
                android:textColor="#888888"
                android:visibility="gone" />

            <ListView
                android:id="@+id/lvTasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:divider="@android:color/transparent"
                android:dividerHeight="10dp"
                android:nestedScrollingEnabled="true"
                android:overScrollMode="never" />
        </LinearLayout>

        <!-- Hidden Children List: If you still need it for context, otherwise it's gone from view -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChildren"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>