<?xml version="1.0" encoding="utf-8"?>
<!-- דשבורד הורה — מסך ראשי אחרי התחברות.
     מציג: סיכום משימות (מספרים) + רשימת כל המשימות + כפתורי ניווט.
     לחיצה על משימה ברשימה → פרטים + אפשרות לשנות תאריך או למחוק. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- כותרת -->
    <TextView
        android:text="דשבורד הורה"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- === שורת פרופיל: תמונה + שם + כפתור שינוי תמונה === -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- תמונת פרופיל ההורה — עגולה 72dp -->
        <ImageView
            android:id="@+id/ivParentProfile"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:scaleType="centerCrop"
            android:background="#DDDDDD"
            android:contentDescription="תמונת פרופיל" />

        <!-- שם ההורה -->
        <TextView
            android:id="@+id/tvParentName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textSize="18sp"
            android:textStyle="bold"
            android:text="" />

        <!-- כפתור קטן לשינוי תמונת הפרופיל -->
        <Button
            android:id="@+id/btnChangeProfilePic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="שנה תמונה"
            android:textSize="12sp"
            android:backgroundTint="#607D8B" />

    </LinearLayout>

    <!-- === סיכום מספרי: משימות / הושלמו / דחופות === -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvParentTotalTasks"
            android:text="משימות: 0"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvParentCompleted"
            android:text="הושלמו: 0"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvParentDueSoon"
            android:text="דחופות: 0"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- === כותרת רשימת משימות === -->
    <TextView
        android:text="משימות שהוקצו:"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- הודעה כשאין משימות -->
    <TextView
        android:id="@+id/tvNoTasks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="אין משימות עדיין"
        android:textColor="#888888"
        android:gravity="center"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

    <!-- רשימת משימות — לחיצה פותחת פרטים + שינוי תאריך / מחיקה -->
    <ListView
        android:id="@+id/lvTasks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#EEEEEE"
        android:dividerHeight="1dp" />

    <!-- === כפתורי ניווט === -->

    <Button
        android:id="@+id/btnManageChildren"
        android:text="ניהול ילדים"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btnManageTemplates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="מאגר תבניות (בנק משימות)"
        android:backgroundTint="#607D8B" />

    <Button
        android:id="@+id/btnAssignTaskToChild"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="שלח משימה לילד"
        android:backgroundTint="#4CAF50" />

    <Button
        android:id="@+id/btnShowQR"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="QR לילדים"
        android:backgroundTint="#3F51B5" />

    <!-- כפתור התנתקות -->
    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="התנתק"
        android:backgroundTint="#F44336"
        android:textColor="#FFFFFF" />

</LinearLayout>
