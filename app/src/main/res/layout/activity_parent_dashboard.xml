<?xml version="1.0" encoding="utf-8"?>
<!-- דשבורד הורה — Hub ניווט מרכזי.
     כפתורים: ניהול ילדים, מאגר תבניות, הקצאת משימה, QR, התנתקות.
     TODO(P1): tvParentTotalTasks/tvParentCompleted/tvParentDueSoon לא מחוברים לנתונים —
               מציגים "0" קבוע. צריך לטעון סיכומים מ-Firebase. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <Button
        android:id="@+id/btnManageChildren"
        android:text="ניהול ילדים"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:text="דשבורד הורה"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvParentTotalTasks"
            android:text="משימות: 0"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvParentCompleted"
            android:text="הושלמו: 0"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvParentDueSoon"
            android:text="דחופות: 0"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <TextView
        android:text="משימות נוכחיות"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center">

        <TextView
            android:text="אין משימות עדיין"
            android:textColor="#888888"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <Button
        android:id="@+id/btnManageTemplates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. ניהול מאגר תבניות (בנק משימות)"
        android:backgroundTint="#607D8B" />

    <Button
        android:id="@+id/btnAssignTaskToChild"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="2. שלח משימה לילד מהמאגר"
        android:backgroundTint="#4CAF50" />

    <Button
        android:id="@+id/btnShowQR"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="3. QR לילדים (בחר ילד והצג קוד)"
        android:backgroundTint="#3F51B5" />

    <!-- כפתור התנתקות -->
    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="התנתק"
        android:backgroundTint="#F44336"
        android:textColor="#FFFFFF" />

</LinearLayout>