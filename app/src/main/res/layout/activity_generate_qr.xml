<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:layoutDirection="rtl"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".parent.GenerateQRActivity">

    <!-- כותרת המסך -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title_qr_family"
        android:textColor="@color/primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- הסבר קצר על השימוש בקוד -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/subtitle_qr_family"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <!-- אזור קבוע שבו מוצג קוד ה-QR -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:layout_marginTop="32dp">

        <ImageView
            android:id="@+id/imageViewQrCode"
            android:layout_width="230dp"
            android:layout_height="230dp"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_qr_code"
            android:scaleType="fitCenter"
            android:visibility="gone" />
    </FrameLayout>

    <!-- טקסט קצר מתחת לקוד -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="@string/qr_share_hint"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnBackToDashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/btn_back_to_dashboard" />

</LinearLayout>
