<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:fillViewport="true"
    android:layoutDirection="rtl"
    android:overScrollMode="never"
    tools:context=".auth.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:animateLayoutChanges="true"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding_compact"
        android:paddingTop="@dimen/screen_padding_top"
        android:paddingEnd="@dimen/screen_padding_compact"
        android:paddingBottom="@dimen/screen_padding_bottom">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_hero"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/Widget.Family.Eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_welcome_eyebrow" />

                <TextView
                    style="@style/Widget.Family.HeroTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/app_name" />

                <TextView
                    style="@style/Widget.Family.HeroSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/home_subtitle" />
            </LinearLayout>

            <ImageView
                android:layout_width="78dp"
                android:layout_height="78dp"
                android:layout_marginStart="12dp"
                android:alpha="0.9"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_home_family" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:minHeight="300dp"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_role_parent_card"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:background="@drawable/bg_avatar_placeholder"
                    android:padding="9dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/home_parent_section_title"
                        android:src="@drawable/ic_role_parent" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Widget.Family.RoleTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_parent_section_title" />

                    <TextView
                        style="@style/Widget.Family.RoleBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/home_parent_section_subtitle" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnLogin"
                    style="@style/Widget.Family.PrimaryButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_login"
                    android:text="@string/parents_login" />

                <Button
                    android:id="@+id/btnRegister"
                    style="@style/Widget.Family.PrimaryButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_person_add"
                    android:text="@string/register_parents" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_role_child_card"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:background="@drawable/bg_avatar_placeholder"
                    android:padding="9dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/home_child_section_title"
                        android:src="@drawable/ic_role_child" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Widget.Family.RoleTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_child_section_title" />

                    <TextView
                        style="@style/Widget.Family.RoleBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/home_child_section_subtitle" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnChildQR"
                    style="@style/Widget.Family.ChildOutlineButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_qr_code_scanner"
                    android:text="@string/child_login_qr" />

                <Button
                    android:id="@+id/btnChild"
                    style="@style/Widget.Family.ChildOutlineButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_child_care"
                    android:text="@string/child_direct_login" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
