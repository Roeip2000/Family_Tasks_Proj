<?xml version="1.0" encoding="utf-8"?>
<!-- כרטיס משימה — מציג תמונה, כותרת, תאריך יעד, כוכבים, נקודת סטטוס, כפתור "בוצע".
     רקע לבן רגיל — הAdaptor יכול לשנות ל-#E8F5E9 (ירוק בהיר) כשהמשימה בוצעה.
     משמש ב-ChildTaskAdapter עם RecyclerView. -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- === צד שמאל: תמונת המשימה (56dp) — גלויה רק אם יש תמונה === -->
        <ImageView
            android:id="@+id/imgTaskImage"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:layout_marginEnd="12dp"
            android:background="#F5F5F5"
            android:contentDescription="תמונת משימה" />

        <!-- === אייקון סטטוס: עיגול צבעוני (ירוק=בוצע, כתום=דחוף, אפור=רגיל) ===
             נמצא לפני הטקסט — ממוקם צמוד לתמונה או לקצה -->
        <View
            android:id="@+id/viewStatusDot"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginEnd="10dp"
            android:background="@android:drawable/radiobutton_off_background" />

        <!-- === חלק טקסטואלי: כותרת + זמן שנותר + כוכבים === -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">

            <!-- כותרת המשימה — bold, 2 שורות מקסימום -->
            <TextView
                android:id="@+id/tvTaskTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="שם המשימה"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- זמן שנותר / תאריך יעד — הצבע נקבע ב-Adapter לפי סטטוס -->
            <TextView
                android:id="@+id/tvDueDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="היום"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginTop="3dp" />

            <!-- כוכבים שאפשר להרוויח — מוסתר אם 0 -->
            <TextView
                android:id="@+id/tvTaskStars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#FFB300"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- === כפתור "בוצע" — מוצג רק אם לא הושלם, מוסתר אם כבר בוצע === -->
        <Button
            android:id="@+id/btnDone"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="6dp"
            android:text="✓ בוצע"
            android:textSize="12sp"
            android:backgroundTint="#7B61FF"
            android:textColor="#FFFFFF"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
