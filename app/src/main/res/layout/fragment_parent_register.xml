<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_star_pill"
    android:backgroundTint="@color/white"
    android:orientation="vertical"
    android:padding="24dp"
    android:layoutDirection="rtl">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="הרשמת הורה"
        android:textColor="@color/primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etFirstName"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_repository_list"
        android:hint="שם פרטי"
        android:paddingHorizontal="16dp"
        android:textSize="15sp" />

    <View android:layout_width="1dp" android:layout_height="10dp" />

    <EditText
        android:id="@+id/etLastName"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_repository_list"
        android:hint="שם משפחה"
        android:paddingHorizontal="16dp"
        android:textSize="15sp" />

    <View android:layout_width="1dp" android:layout_height="10dp" />

    <EditText
        android:id="@+id/etEmail"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_repository_list"
        android:hint="אימייל"
        android:inputType="textEmailAddress"
        android:paddingHorizontal="16dp"
        android:textSize="15sp" />

    <View android:layout_width="1dp" android:layout_height="10dp" />

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_repository_list"
        android:hint="סיסמה"
        android:inputType="textPassword"
        android:paddingHorizontal="16dp"
        android:textSize="15sp" />

    <Button
        android:id="@+id/btnRegister"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/primary"
        android:text="יצירת חשבון"
        android:textColor="@color/white"
        app:cornerRadius="12dp" />

    <ProgressBar
        android:id="@+id/progressRegister"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

</LinearLayout>