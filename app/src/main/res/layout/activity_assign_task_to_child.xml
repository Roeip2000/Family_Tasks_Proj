<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fillViewport="true"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- כותרת המסך -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_assign_task"
            android:textColor="@color/primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- הסבר קצר -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/subtitle_assign_task"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- בחירת תבנית משימה -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/label_choose_template"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- הסבר קצר: ה-Spinner מאפשר להחליף בין התבניות -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/hint_change_template"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/spTemplates"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_spinner"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:spinnerMode="dropdown" />

        <!-- אזור קבוע לתמונת התבנית -->
        <ImageView
            android:id="@+id/imgTaskPreview"
            android:layout_width="150dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:contentDescription="@string/cd_task_image"
            android:scaleType="centerCrop" />

        <!-- שם המשימה -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/label_task_name"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etTitle"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_repository_list"
            android:hint="@string/hint_task_name"
            android:importantForAutofill="no"
            android:inputType="text"
            android:paddingHorizontal="16dp"
            android:textSize="16sp" />

        <!-- בחירת ילד -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/label_assign_to"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spAssignee"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_spinner"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:spinnerMode="dropdown" />

        <!-- תאריך יעד -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/label_due_date"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etDueDate"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_repository_list"
            android:focusable="false"
            android:hint="@string/hint_select_date"
            android:importantForAutofill="no"
            android:inputType="date"
            android:paddingHorizontal="16dp"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnAssign"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:backgroundTint="@color/primary"
            android:text="@string/btn_confirm_assign"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/btnBackToDashboard"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/btn_cancel_back"
            android:textColor="@color/text_secondary" />

    </LinearLayout>
</ScrollView>
