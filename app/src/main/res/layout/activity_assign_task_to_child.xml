<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:fillViewport="true"
    tools:context=".Parents_Dashbord_and_mange.AssignTaskToChildActivity">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="18dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <!-- כותרת מסך שליחת משימה -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_hero"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                style="@style/Widget.Family.ScreenTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/title_assign_task"
                android:textSize="22sp" />

            <TextView
                style="@style/Widget.Family.ScreenSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/subtitle_assign_task"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- תצוגה מקדימה של התבנית שנבחרה -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_repository_list"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <FrameLayout
                android:id="@+id/cvImagePreview"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:background="@drawable/bg_preview_shell"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/imgTaskPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/cd_task_preview"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_image_placeholder" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/Widget.Family.PanelTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/assign_task_preview_label" />

                <TextView
                    style="@style/Widget.Family.PanelSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/subtitle_assign_task" />
            </LinearLayout>
        </LinearLayout>

        <!-- טופס בחירת תבנית, ילד ותאריך יעד -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border_light"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/Widget.Family.SectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/assign_task_form_title"
                    android:textSize="17sp" />

                <TextView
                    style="@style/Widget.Family.Eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="מה המשימה?" />

                <TextView
                    style="@style/Widget.Family.FieldLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/label_choose_template" />


                <Spinner
                    android:id="@+id/spTemplates"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_spinner" />

                <TextView
                    style="@style/Widget.Family.FieldLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/hint_task_title_assign" />

                <EditText
                    android:id="@+id/etTitle"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="@string/hint_task_title_assign"
                    android:inputType="text"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="24dp"
                    android:background="@color/divider" />

                <TextView
                    style="@style/Widget.Family.Eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="למי ומתי?" />

                <TextView
                    style="@style/Widget.Family.FieldLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/label_assign_to_child" />

                <Spinner
                    android:id="@+id/spAssignee"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_spinner" />

                <TextView
                    style="@style/Widget.Family.FieldLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/hint_due_date" />

                <EditText
                    android:id="@+id/etDueDate"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_field"
                    android:clickable="true"
                    android:drawableEnd="@drawable/ic_due_calendar"
                    android:focusable="false"
                    android:hint="@string/hint_due_date"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnAssign"
            style="@style/Widget.Family.PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/btn_assign_task" />

        <Button
            android:id="@+id/btnBackToDashboard"
            style="@style/Widget.Family.BackButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/btn_back_to_dashboard" />

    </LinearLayout>
</ScrollView>
