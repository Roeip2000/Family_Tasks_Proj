<?xml version="1.0" encoding="utf-8"?>
<!--
 צ'יפ ילד דק בלבד — אווטאר + שם, כדי שהבחירה בילד לא תתחרה עם רשימת המשימות.
 מצב נבחר מתקבל על-ידי החלפת רקע ב-Adapter.
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardChildSummary"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="8dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/border_light"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="48dp"
        android:orientation="horizontal"
        android:paddingStart="6dp"
        android:paddingTop="6dp"
        android:paddingEnd="14dp"
        android:paddingBottom="6dp">

        <ImageView
            android:id="@+id/ivChildSummaryPhoto"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_avatar_placeholder"
            android:clipToOutline="true"
            android:contentDescription="@string/cd_child_avatar"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/tvChildSummaryName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- שדה משני שמור ב-layout למרות שהעיצוב החדש לא מציג אותו —
             כדי לא לשבור את ה-Adapter שעדיין כותב אליו טקסט סטטיסטי. -->
        <TextView
            android:id="@+id/tvChildSummaryAssigned"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
