<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:layoutDirection="rtl"
    android:orientation="vertical">

    <!-- אזור גליל: כל תוכן המסך -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- כותרת המסך -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_task_templates"
                android:textColor="@color/primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- הסבר קצר -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/subtitle_task_templates"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <!-- שם התבנית -->
            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_repository_list"
                android:hint="@string/hint_template_title"
                android:importantForAutofill="no"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textSize="16sp" />

            <!-- תמונת התבנית -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/label_task_image"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- שורת תמונה: מקום קבוע לתמונה וכפתור בחירה לידו -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgTask"
                    android:layout_width="110dp"
                    android:layout_height="80dp"
                    android:contentDescription="@string/cd_task_image"
                    android:scaleType="centerCrop" />

                <Button
                    android:id="@+id/btnPickImage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/btn_pick_image" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/primary"
                android:text="@string/btn_save_template"
                android:textColor="@color/white" />

            <!-- רשימת התבניות הקיימות -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="8dp"
                android:text="@string/title_existing_templates"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ListView
                android:id="@+id/lvTemplates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:cacheColorHint="@android:color/transparent"
                android:listSelector="@android:color/transparent"
                android:nestedScrollingEnabled="false"
                tools:ignore="NestedScrolling" />

        </LinearLayout>
    </ScrollView>

    <!-- כפתור משני קבוע בתחתית: חזרה לדשבורד (תמיד נגיש) -->
    <Button
        android:id="@+id/btnBackToDashboard"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:text="@string/btn_back_to_dashboard"
        android:textAllCaps="false" />

</LinearLayout>
