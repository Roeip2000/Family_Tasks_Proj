<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="18dp"
    android:paddingEnd="16dp"
    android:paddingBottom="20dp">

    <TextView
        style="@style/Widget.Family.ScreenTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:text="@string/template_screen_title"
        android:textSize="22sp" />

    <TextView
        style="@style/Widget.Family.ScreenSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="start"
        android:text="@string/template_screen_subtitle"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/layoutForm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_form_card"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvFormTitle"
            style="@style/Widget.Family.SectionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/template_form_title_new"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etTitle"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_field"
            android:hint="@string/hint_task_title"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

        <!-- שדה מספר כוכבים — נשמר על התבנית ומשמש כברירת מחדל להקצאת משימה -->
        <TextView
            style="@style/Widget.Family.FieldLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/label_template_stars" />

        <EditText
            android:id="@+id/etStarsWorth"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_field"
            android:hint="@string/hint_template_stars"
            android:inputType="number"
            android:maxLength="3"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

        <!-- מסגרת מעוגלת לתמונה — נראית כמו כרטיס מקדמה ולא כמו ImageView חשוף -->
        <androidx.cardview.widget.CardView
            android:layout_width="124dp"
            android:layout_height="124dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/surface_soft_blue"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/imgTask"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/cd_task_image"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_image_placeholder" />
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnPickImage"
            style="@style/Widget.Family.SecondaryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/btn_pick_image" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSave"
                style="@style/Widget.Family.AccentButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:text="@string/btn_save_template" />

            <Button
                android:id="@+id/btnCancelEdit"
                style="@style/Widget.Family.SecondaryButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="@string/btn_cancel_edit"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- כרטיס רשימת התבניות — מעוצב כמו כרטיס הטופס שמעליו, כדי שההיררכיה
         בין "תבנית חדשה" ל-"תבניות קיימות" תהיה חזקה ויזואלית. -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/border_light"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp">

            <TextView
                style="@style/Widget.Family.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/template_existing_title"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvTemplateListHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:text="@string/template_list_hint"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvNoTemplates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/template_empty_list"
                android:textColor="@color/text_hint"
                android:visibility="gone" />

            <ListView
                android:id="@+id/lvTemplates"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="4dp"
                android:layout_weight="1"
                android:divider="@color/divider"
                android:dividerHeight="1dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <Button
        android:id="@+id/btnBackToDashboard"
        style="@style/Widget.Family.CompactSecondaryButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/btn_back_to_dashboard" />

</LinearLayout>
