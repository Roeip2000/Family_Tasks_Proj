<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:fillViewport="true"
    android:layoutDirection="rtl"
    android:overScrollMode="never">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="18dp"
        android:paddingEnd="16dp"
        android:paddingBottom="56dp">

        <!-- כותרת מאגר התבניות -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_hero"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                style="@style/Widget.Family.ScreenTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/template_screen_title"
                android:textSize="22sp" />

            <TextView
                style="@style/Widget.Family.ScreenSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/template_screen_subtitle" />
        </LinearLayout>

        <!-- טופס יצירה או עריכה של תבנית משימה -->
        <LinearLayout
            android:id="@+id/layoutForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_form_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvFormTitle"
                style="@style/Widget.Family.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/template_form_title_new" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_repository_list"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <FrameLayout
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:background="@drawable/bg_preview_shell"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/imgTask"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/cd_task_image"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_placeholder_image" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Widget.Family.PanelTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/assign_task_preview_label" />

                    <TextView
                        style="@style/Widget.Family.PanelSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/template_list_hint" />

                    <Button
                        android:id="@+id/btnPickImage"
                        style="@style/Widget.Family.SecondaryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:drawableStart="@drawable/ic_camera"
                        android:text="@string/btn_pick_image" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Family.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="@string/hint_task_title"
                app:startIconDrawable="@drawable/ic_assignment">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTitle"
                    style="@style/Widget.Family.TextInputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_task_title"
                    android:imeOptions="actionNext"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Family.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="@string/label_template_stars"
                app:startIconDrawable="@drawable/ic_check">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etStarsWorth"
                    style="@style/Widget.Family.TextInputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_template_stars"
                    android:imeOptions="actionDone"
                    android:inputType="number"
                    android:maxLength="3" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnSave"
                    style="@style/Widget.Family.AccentButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_check"
                    android:text="@string/btn_save_template" />

                <Button
                    android:id="@+id/btnCancelEdit"
                    style="@style/Widget.Family.SecondaryButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="@string/btn_cancel_edit"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <!-- רשימת התבניות הקיימות -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="@dimen/card_corner_radius_large"
            app:cardElevation="0dp"
            app:strokeColor="@color/border_light"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/Widget.Family.Eyebrow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/template_existing_title" />

                <TextView
                    android:id="@+id/tvTemplateListHint"
                    style="@style/Widget.Family.HelperText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/template_list_hint" />

                <TextView
                    android:id="@+id/tvNoTemplates"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_empty_state"
                    android:gravity="center"
                    android:padding="14dp"
                    android:text="@string/template_empty_list"
                    android:textColor="@color/text_hint"
                    android:visibility="gone" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_repository_list"
                    android:padding="8dp">

                    <ListView
                        android:id="@+id/lvTemplates"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:divider="@android:color/transparent"
                        android:dividerHeight="0dp"
                        android:listSelector="@android:color/transparent"
                        android:nestedScrollingEnabled="true" />
                </FrameLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnBackToDashboard"
            style="@style/Widget.Family.BackButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/btn_back_to_dashboard" />

    </LinearLayout>
</ScrollView>
