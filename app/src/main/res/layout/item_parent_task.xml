<?xml version="1.0" encoding="utf-8"?>
<!-- כרטיס משימה ברשימת דשבורד ההורה.
     מציג: תמונת הילד (עגולה), שם המשימה, שם הילד, תאריך יעד, ותג סטטוס.
     הצבעים של התאריך והסטטוס נקבעים ב-TaskItemAdapter לפי מצב המשימה. -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- תמונת הילד — עיגול 48dp. אם אין תמונה, נשאר רקע אפור בהיר -->
        <ImageView
            android:id="@+id/ivChildPhoto"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_avatar_placeholder"
            android:clipToOutline="true"
            android:scaleType="centerCrop"
            android:contentDescription="@string/cd_child_photo" />

        <!-- === עמודת מידע: כותרת + שם ילד + תאריך === -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp">

            <!-- כותרת המשימה — הכי בולטת -->
            <TextView
                android:id="@+id/tvTaskTitleCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_task_name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- שם הילד — קטן יותר, אפרפר -->
            <TextView
                android:id="@+id/tvChildNameCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_child_name"
                android:textSize="13sp"
                android:textColor="#777777"
                android:layout_marginTop="2dp" />

            <!-- תאריך יעד — הצבע נקבע ב-Adapter לפי דחיפות -->
            <TextView
                android:id="@+id/tvDueDateCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_date"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- תג סטטוס — "בוצע / ממתין / איחור" עם רקע צבעוני עגול -->
        <TextView
            android:id="@+id/tvStatusChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/default_status"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
