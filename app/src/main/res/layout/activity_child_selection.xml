<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:fillViewport="true"
    android:layoutDirection="rtl"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding_compact"
        android:paddingTop="@dimen/screen_padding_top"
        android:paddingEnd="@dimen/screen_padding_compact"
        android:paddingBottom="@dimen/screen_padding_bottom">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_hero"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTitle"
                    style="@style/Widget.Family.ScreenTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/title_child_login"
                    android:textColor="@color/md_theme_primary"
                    android:textSize="@dimen/text_title" />

                <TextView
                    android:id="@+id/tvSubtitle"
                    style="@style/Widget.Family.ScreenSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/subtitle_child_login" />
            </LinearLayout>

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginStart="12dp"
                android:contentDescription="@string/title_child_login"
                android:src="@drawable/ic_child_care"
                app:tint="@color/md_theme_primary" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/selectionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="@dimen/card_corner_radius_large"
            app:cardElevation="@dimen/card_elevation"
            app:strokeColor="@color/divider_light"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvParentLabel"
                    style="@style/Widget.Family.FieldLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_choose_parent"
                    android:visibility="gone" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:strokeColor="@color/divider_light"
                    app:strokeWidth="1dp">

                    <Spinner
                        android:id="@+id/spinnerParents"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_spinner"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:spinnerMode="dropdown"
                        android:visibility="gone" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvChildLabel"
                    style="@style/Widget.Family.FieldLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/label_choose_child" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:strokeColor="@color/divider_light"
                    app:strokeWidth="1dp">

                    <Spinner
                        android:id="@+id/spinnerChildren"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_spinner"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:spinnerMode="dropdown" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvNoChildren"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_empty_state"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="@string/empty_no_children_selection"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnEnter"
                    style="@style/Widget.Family.PrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="18dp"
                    android:drawableStart="@drawable/ic_login"
                    android:text="@string/btn_enter" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:indeterminateTint="@color/md_theme_primary"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
