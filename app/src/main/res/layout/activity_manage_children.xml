<?xml version="1.0" encoding="utf-8"?>
<!-- מסך ניהול ילדים — הוספה, צפייה, עריכה ומחיקה.
     בחלק העליון: טופס הוספת ילד חדש + בחירת תמונה לילד.
     בחלק התחתון: רשימת כל הילדים הקיימים (ListView).
     לחיצה על ילד ברשימה → תפריט "ערוך שם" / "מחק ילד". -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    tools:context=".Parents_Dashbord_and_mange.ManageChildrenActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- כותרת -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp"
            android:text="@string/title_manage_children"
            android:textColor="#222"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- === טופס הוספת ילד בכרטיס === -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/border_light"
            app:strokeWidth="1dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/imgChildPhoto"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_avatar_placeholder"
                    android:clipToOutline="true"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/cd_child_photo" />

                <Button
                    android:id="@+id/btnPickChildPhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="@color/primary_light"
                    android:text="@string/btn_pick_child_photo"
                    android:textAllCaps="false"
                    android:textColor="@color/primary_dark"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/etFirstName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/first_name"
                    android:inputType="textPersonName" />

                <EditText
                    android:id="@+id/etLastName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="@string/last_name"
                    android:inputType="textPersonName" />

                <Button
                    android:id="@+id/btnAddChild"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/accent"
                    android:text="@string/add_child"
                    android:textAllCaps="false"
                    android:textColor="@color/white" />

                <Button
                    android:id="@+id/btnCancelEdit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:backgroundTint="#9E9E9E"
                    android:text="@string/btn_cancel_edit"
                    android:textAllCaps="false"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- === כותרת רשימת ילדים === -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/label_registered_children"
            android:textColor="#333"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- הודעה כשאין ילדים -->
        <TextView
            android:id="@+id/tvNoChildren"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/empty_no_children"
            android:textColor="#999"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- רשימת ילדים — לחיצה פותחת תפריט ערוך/מחק
             גובה קבוע כי ScrollView לא יכולה להכיל ListView עם weight -->
        <ListView
            android:id="@+id/lvChildren"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:divider="#EEEEEE"
            android:dividerHeight="1dp" />

        <!-- כפתור חזרה לדשבורד ההורה -->
        <Button
            android:id="@+id/btnBackToDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="#E8F1FB"
            android:text="@string/btn_back_to_dashboard"
            android:textAllCaps="false"
            android:textColor="#1F4E79" />

    </LinearLayout>

</ScrollView>
