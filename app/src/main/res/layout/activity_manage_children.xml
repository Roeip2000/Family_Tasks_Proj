<?xml version="1.0" encoding="utf-8"?>
<!-- מסך ניהול ילדים — הוספה, צפייה, עריכה ומחיקה.
     בחלק העליון: טופס הוספת ילד חדש + בחירת תמונה לילד.
     בחלק התחתון: רשימת כל הילדים הקיימים (ListView).
     לחיצה על ילד ברשימה → תפריט "ערוך שם" / "מחק ילד". -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Parents_Dashbord_and_mange.ManageChildrenActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- כותרת -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp"
            android:text="@string/title_manage_children"
            android:textColor="#222"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- === תמונת פרופיל לילד === -->

        <!-- עיגול אפור — מחזיק את תמונת הילד לפני הבחירה -->
        <ImageView
            android:id="@+id/imgChildPhoto"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_avatar_placeholder"
            android:clipToOutline="true"
            android:scaleType="centerCrop"
            android:contentDescription="@string/cd_child_photo" />

        <!-- כפתור בחירת תמונה מהגלריה -->
        <Button
            android:id="@+id/btnPickChildPhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#607D8B"
            android:text="@string/btn_pick_child_photo"
            android:textColor="#FFFFFF" />

        <!-- === טופס הוספת ילד === -->

        <EditText
            android:id="@+id/etFirstName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/first_name"
            android:inputType="textPersonName" />

        <EditText
            android:id="@+id/etLastName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/last_name"
            android:inputType="textPersonName" />

        <Button
            android:id="@+id/btnAddChild"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="#4CAF50"
            android:text="@string/add_child" />

        <!-- כפתור ביטול עריכה — מוצג רק כשעורכים ילד קיים -->
        <Button
            android:id="@+id/btnCancelEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:backgroundTint="#9E9E9E"
            android:text="@string/btn_cancel_edit"
            android:visibility="gone" />

        <!-- === קו מפריד בין הטופס לרשימה === -->

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:background="#DDDDDD" />

        <!-- === כותרת רשימת ילדים === -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/label_registered_children"
            android:textColor="#333"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- הודעה כשאין ילדים -->
        <TextView
            android:id="@+id/tvNoChildren"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/empty_no_children"
            android:textColor="#999"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- רשימת ילדים — לחיצה פותחת תפריט ערוך/מחק
             גובה קבוע כי ScrollView לא יכולה להכיל ListView עם weight -->
        <ListView
            android:id="@+id/lvChildren"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:divider="#EEEEEE"
            android:dividerHeight="1dp" />

    </LinearLayout>

</ScrollView>
